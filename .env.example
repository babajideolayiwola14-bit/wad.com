# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (required — use Render internal/external database URL locally)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Set to false only for local Postgres without SSL
# DATABASE_SSL=false

# Security
SECRET_KEY=your-super-secret-key-change-this-min-32-chars
JWT_EXPIRY=86400
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# App URL (Render service URL, used in password-reset emails)
APP_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Upload limits
MAX_FILE_SIZE=10485760
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4

# SMTP (optional — password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
DEV_SHOW_RESET_TOKEN=false
